---
import ProjectCard from "@/components/ProjectCard.astro";
import Layout from "../layouts/Layout.astro";
import { ModeToggle } from "@/components/ModeToggle";
import { projects } from "@/data/projects";

// Function to shuffle array
function shuffleArray<T>(array: T[]): T[] {
  for (let i = array.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [array[i], array[j]] = [array[j], array[i]];
  }
  return array;
}

// Shuffle the projects array
const shuffledProjects = shuffleArray([...projects]);
---

<Layout title="Vanilla JS Corner - Simple Projects">
  <main>
    <a
      href="https://github.com/ChiragDalmia/CSSLibrary"
      target="_blank"
      rel="noopener noreferrer"
      class="fixed top-5 right-7 z-50 flex h-10 w-10 items-center justify-center rounded-full transition-colors hover:bg-accent"
      aria-label="View this project on GitHub"
    >
      <svg
        viewBox="0 0 24 24"
        xmlns="http://www.w3.org/2000/svg"
        class="h-6 w-6 fill-current"
        aria-hidden="true"
      >
        <path
          d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"
        ></path>
      </svg>
    </a>
    <h1
      class="mt-10 text-center text-4xl font-bold sm:text-5xl md:text-6xl lg:text-7xl"
    >
      Vanilla JS Corner
    </h1>
    <p class="mt-4 text-center text-xl">
      A collection of simple JavaScript projects
    </p>

    <!-- card -->
    <div
      class="mx-auto my-16 flex max-w-[90%] flex-wrap items-center justify-center gap-4 align-middle"
    >
      {
        shuffledProjects.map((project) => (
          <div class="w-full sm:w-1/2 md:w-1/3 lg:w-1/4">
            <ProjectCard project={project} />
          </div>
        ))
      }
    </div>

    <div class="fixed right-7 bottom-14 z-50">
      <ModeToggle client:load />
    </div>
  </main>
</Layout>
